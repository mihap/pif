{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Design Guide Demo Data",
  "type": "object",
  "required": ["guideName", "version", "description", "stylesheet", "sections"],
  "properties": {
    "guideName": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^Version \\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "description": { "type": "string", "minLength": 1 },
    "stylesheet": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![a-zA-Z][a-zA-Z0-9+.-]*:)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "sourceChapter", "description", "examples"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "title": { "type": "string", "minLength": 1 },
          "sourceChapter": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "examples": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "title", "description", "type", "tokens"],
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                "title": { "type": "string", "minLength": 1 },
                "description": { "type": "string", "minLength": 1 },
                "type": {
                  "type": "string",
                  "enum": ["color", "typography", "spacing", "surface", "state", "form", "button", "navigation", "table", "feedback", "screen"]
                },
                "tokens": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                },
                "props": {
                  "type": "object",
                  "additionalProperties": true
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
